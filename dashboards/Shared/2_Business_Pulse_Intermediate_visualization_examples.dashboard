    show_x_axis_label: true
    show_x_axis_ticks: true
    y_axis_scale_mode: linear
    x_axis_reversed: false
    y_axis_reversed: false
    plot_size_by_field: false
    trellis: ''
    stacking: normal
    limit_displayed_rows: false
    legend_position: right
    point_style: circle
    show_value_labels: true
    label_density: 25
    x_axis_scale: auto
    y_axis_combined: true
    ordering: none
    show_null_labels: false
    show_totals_labels: true
    show_silhouette: false
    totals_color: "#80868B"
    y_axes: [{label: '', orientation: left, series: [{axisId: 1 - Processing - 0|FIELD|Processing
              - order_items.count, id: 1 - Processing - 0|FIELD|Processing - order_items.count,
            name: 1 - Processing - Processing}, {axisId: 1x - Cancelled - 1|FIELD|Cancelled
              - order_items.count, id: 1x - Cancelled - 1|FIELD|Cancelled - order_items.count,
            name: 1x - Cancelled - Cancelled}, {axisId: 2 - Shipped - 2|FIELD|Shipped
              - order_items.count, id: 2 - Shipped - 2|FIELD|Shipped - order_items.count,
            name: 2 - Shipped - Shipped}, {axisId: 3 - Complete - 3|FIELD|Complete
              - order_items.count, id: 3 - Complete - 3|FIELD|Complete - order_items.count,
            name: 3 - Complete - Complete}, {axisId: 3x - Complete - 4|FIELD|Returned
              - order_items.count, id: 3x - Complete - 4|FIELD|Returned - order_items.count,
            name: 3x - Complete - Returned}], showLabels: false, showValues: false,
        valueFormat: "#.#,k", unpinAxis: false, tickDensity: default, type: linear}]
    x_axis_zoom: true
    y_axis_zoom: true
    font_size: ''
    label_value_format: "#.#,k"
    series_colors:
