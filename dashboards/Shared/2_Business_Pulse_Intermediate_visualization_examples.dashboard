  elements:
  - title: Order Items by Status
    name: Order Items by Status
    model: intermediate_ecomm
    explore: intermediate_example_ecommerce
    type: looker_column
    fields: [order_items.count, order_items.status, order_items.status_in_order, order_items.validation_status]
    pivots: [order_items.status_in_order, order_items.status]
    fill_fields: [order_items.validation_status]
    sorts: [order_items.status_in_order, order_items.status, order_items.count desc
        0]
    limit: 500
    column_limit: 50
    x_axis_gridlines: false
    y_axis_gridlines: true
    show_view_names: false
    show_y_axis_labels: true
    show_y_axis_ticks: true
    y_axis_tick_density: default
