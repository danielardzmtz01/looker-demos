  - title: Average Sales Price
    name: Average Sales Price
    model: advanced_ecomm
    explore: advanced_example_ecommerce
    type: single_value
    fields: [order_items.average_sale_price, user_summary_unfiltered.average_sale_price_for_these_users,
      user_summary_and_order_items_fields.filtered_average_vs_unfiltered_average]
    filters:
      order_items.validation_status: ''
    limit: 500
    column_limit: 50
    custom_color_enabled: true
    show_single_value_title: true
    show_comparison: true
    comparison_type: value
    comparison_reverse_colors: false
    show_comparison_label: true
    enable_conditional_formatting: false
    conditional_formatting_include_totals: false
    conditional_formatting_include_nulls: false
    comparison_label: "(vs Buyers' Lifetime Avg)"
    defaults_version: 1
    hidden_pivots: {}
    hidden_fields: [user_summary_unfiltered.average_sale_price_for_these_users]
    y_axes: []
    listen:
      Priority Items Only Toggle: priority_item_filter_feature_support.priority_items_only_toggle
      Created Date: order_items.created_at_date
      Department: products.department
      Category: products.category
      Brand: products.brand
      Product Name: products.name
      User Revenue Rank Group (Lifetime): user_summary_unfiltered.user_revenue_rank_group
      User Country: users.country
      User State: users.state
    row: 4
    col: 5
    width: 5
    height: 4
